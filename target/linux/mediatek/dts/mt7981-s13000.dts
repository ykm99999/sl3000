/dts-v1/;

/include/ "mt7981.dtsi"

/ {
    model = "SL3000 Router (MT7981)";
    compatible = "sl,sl3000", "mediatek,mt7981";

    aliases {
        serial0 = &uart0;
    };

    chosen {
        stdout-path = "serial0:115200n8";
    };

    memory@40000000 {
        device_type = "memory";
        reg = <0x40000000 0x40000000>; /* 1GB */
    };

    leds {
        compatible = "gpio-leds";

        status {
            label = "sl3000:blue:status";
            gpios = <&gpio 10 GPIO_ACTIVE_LOW>;
        };

        wan {
            label = "sl3000:blue:wan";
            gpios = <&gpio 11 GPIO_ACTIVE_LOW>;
        };

        lan {
            label = "sl3000:green:lan";
            gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
        };
    };

    keys {
        compatible = "gpio-keys";

        reset {
            label = "reset";
            linux,code = <KEY_RESTART>;
            gpios = <&gpio 9 GPIO_ACTIVE_LOW>;
        };
    };
};

/* UART */
&uart0 {
    status = "okay";
};

/* WiFi */
&wifi {
    status = "okay";
    mediatek,mtd-eeprom = <&factory 0x0>;
};

/* Ethernet */
&eth {
    status = "okay";
};

&mdio {
    status = "okay";
};

/* ✅ USB 全部移除，不启用 USB PHY、不启用 xHCI */
/* 以下节点不再出现：
   &usb_phy
   &xhci
*/
