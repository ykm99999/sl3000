CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_sl3000=y

# 内核
CONFIG_KERNEL_BUILD_USER="immortal"
CONFIG_KERNEL_BUILD_DOMAIN="wrt"
CONFIG_LINUX_6_12=y

# 基础系统
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_opkg=y

# 网络
CONFIG_PACKAGE_mtkhnat=y
CONFIG_PACKAGE_mtketh=y
CONFIG_PACKAGE_mtk-ppe=y
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-mediatek_eth=y

# eMMC 支持
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-mtk=y

# WiFi（MT7976CN）
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt76-connac-lib=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y

# LED / 按键
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y

# UBI / rootfs
CONFIG_PACKAGE_kmod-ubifs=y
CONFIG_PACKAGE_kmod-ubi=y
CONFIG_PACKAGE_ubi-utils=y

# LuCI（可选）
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 去掉 USB（你的设备没有）
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=n

# 去掉蓝牙（如果没有）
CONFIG_PACKAGE_kmod-bluetooth=n

# 去掉音频（没有）
CONFIG_PACKAGE_kmod-sound-core=n

# 去掉 PCIe（如果你的 WiFi 不是 PCIe）
CONFIG_PACKAGE_kmod-pcie-mtk=n

# 其他优化
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KERNEL_KALLSYMS=n
CONFIG_KERNEL_KALLSYMS_ALL=n
CONFIG_KERNEL_DEBUG_FS=n
